# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in the values.
# Never commit your real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Flask core
FLASK_ENV=development           # development | production
SECRET_KEY=change-me-to-a-long-random-string

# JWT
JWT_SECRET_KEY=change-me-to-another-long-random-string

# Database  (SQLite for dev, Postgres for prod)
DATABASE_URL=sqlite:///aptitude.db
# DATABASE_URL=postgresql://user:password@localhost:5432/aptitude

# Groq AI
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-8b-8192
GROQ_FALLBACK_MODEL=llama3-70b-8192

# Rate limiting storage (use Redis in production)
RATELIMIT_STORAGE_URI=memory://
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# Admin promotion secret (optional)
ADMIN_SECRET_KEY=

# Gunicorn (production)
GUNICORN_BIND=0.0.0.0:5000
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30

# Logging
LOG_LEVEL=info
